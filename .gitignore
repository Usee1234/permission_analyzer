# --- apktool decompiled output ---
# These change with every APK analyzed and should NOT be tracked in git
apk_decoded/

# --- Python bytecode / cache ---
__pycache__/
*.pyc
*.pyo
*.pyd
*.pyc.txt  # sometimes generated by error redirects

# --- Virtual environments ---
venv/
.venv/
env/
.env/

# --- Generated audit reports ---
# JSON reports are regenerated per pipeline run and should not be versioned
audit_report*.json

# --- ChromaDB vector store ---
# The vector index is built from normalized data and can be regenerated
db/chroma/

# --- IDE / editor settings ---
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# --- Environment / secrets ---
# API keys and config should never be committed
.env
.env.local
.env.*.local

# --- OS generated files ---
.DS_Store
Thumbs.db
desktop.ini

# --- Logs / temporary files ---
*.log
*.tmp
*.temp
out/
logs/

# --- pip / build artifacts ---
*.egg-info/
dist/
build/
*.egg
wheels/